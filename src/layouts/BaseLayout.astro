---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'Personal portfolio and blog' } = Astro.props
const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
    <!-- Prevent flash of wrong theme: runs synchronously before first paint -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme')
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark')
        }
      })()
    </script>
  </head>
  <body class="bg-white dark:bg-zinc-950 text-slate-900 dark:text-zinc-100 antialiased transition-colors duration-200">
    <div class="mx-auto max-w-3xl px-6">

      <header class="flex items-center justify-between py-8 border-b border-slate-200 dark:border-zinc-800">
        <a href="/" class="font-semibold tracking-tight text-slate-900 dark:text-zinc-100 hover:text-slate-500 dark:hover:text-zinc-400 transition-colors">
          Kisan Thapa
        </a>

        <div class="flex items-center gap-5">
          <nav class="flex gap-5 text-sm text-slate-600 dark:text-zinc-400">
            <a
              href="/publications"
              class:list={[
                'hover:text-slate-900 dark:hover:text-zinc-100 transition-colors',
                currentPath.startsWith('/publications') && 'text-slate-900 dark:text-zinc-100 font-medium',
              ]}
            >
              Publications
            </a>
            <a
              href="/projects"
              class:list={[
                'hover:text-slate-900 dark:hover:text-zinc-100 transition-colors',
                currentPath.startsWith('/projects') && 'text-slate-900 dark:text-zinc-100 font-medium',
              ]}
            >
              Projects
            </a>
            <a
              href="/blog"
              class:list={[
                'hover:text-slate-900 dark:hover:text-zinc-100 transition-colors',
                currentPath.startsWith('/blog') && 'text-slate-900 dark:text-zinc-100 font-medium',
              ]}
            >
              Blog
            </a>
            <a
              href="/about"
              class:list={[
                'hover:text-slate-900 dark:hover:text-zinc-100 transition-colors',
                (currentPath === '/about' || currentPath === '/about/') && 'text-slate-900 dark:text-zinc-100 font-medium',
              ]}
            >
              About
            </a>
          </nav>

          <!-- Dark / light toggle -->
          <button
            id="theme-toggle"
            aria-label="Toggle dark mode"
            class="text-slate-500 dark:text-zinc-400 hover:text-slate-900 dark:hover:text-zinc-100 transition-colors"
          >
            <!-- Moon icon — visible in light mode -->
            <svg
              class="block dark:hidden w-[1.1rem] h-[1.1rem]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
            <!-- Sun icon — visible in dark mode -->
            <svg
              class="hidden dark:block w-[1.1rem] h-[1.1rem]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="5" />
              <line x1="12" y1="1" x2="12" y2="3" />
              <line x1="12" y1="21" x2="12" y2="23" />
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
              <line x1="1" y1="12" x2="3" y2="12" />
              <line x1="21" y1="12" x2="23" y2="12" />
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
            </svg>
          </button>
        </div>
      </header>

      <main class="py-12">
        <slot />
      </main>

      <footer class="py-8 border-t border-slate-200 dark:border-zinc-800 text-sm text-slate-500 dark:text-zinc-500 flex justify-between items-center">
        <span>© Kisan Thapa</span>
        <div class="flex gap-5">
          <a
            href="https://github.com/KisanThapa"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-slate-900 dark:hover:text-zinc-100 transition-colors"
          >GitHub</a>
          <a
            href="https://www.linkedin.com/in/kisanthapa/"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-slate-900 dark:hover:text-zinc-100 transition-colors"
          >LinkedIn</a>
          <a
            href="https://scholar.google.com/citations?user=4Qs3ndUAAAAJ&hl=en"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-slate-900 dark:hover:text-zinc-100 transition-colors"
          >Scholar</a>
        </div>
      </footer>

    </div>

    <script is:inline>
      document.getElementById('theme-toggle').addEventListener('click', function () {
        const isDark = document.documentElement.classList.toggle('dark')
        localStorage.setItem('theme', isDark ? 'dark' : 'light')
      })
    </script>
  </body>
</html>
