---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3)

const education = [
  {
    period: '2021 – Present',
    degree: 'PhD in Computer Science',
    school: 'University of Massachusetts Boston',
  },
  {
    period: '2021 – 2025',
    degree: 'Master of Science in Computer Science',
    school: 'University of Massachusetts Boston',
  },
  {
    period: '2013 – 2017',
    degree: 'Bachelor of Computer Engineering',
    school: 'Pokhara University, Nepal',
  },
]

const interests = [
  'Computational Biology',
  'Deep Learning',
  'Graph Neural Networks',
  'Machine Learning',
  'Bioinformatics',
  'Software Engineering',
]

const skills = {
  Languages: ['Python', 'Java', 'JavaScript', 'R', 'SQL'],
  Tools: ['PyTorch', 'TensorFlow', 'Scikit-Learn', 'Docker', 'Git'],
}

const news = [
  {
    date: 'Dec 2025',
    title: "Awarded CSM Dean's Doctoral Research Fellowship",
    detail: 'Sponsored by Oracle and UMass Boston.',
    link: undefined,
  },
  {
    date: 'May 2025',
    title: 'Received Master of Science in Computer Science',
    detail: 'En-route MS from University of Massachusetts Boston.',
    link: undefined,
  },
  {
    date: 'Mar 2025',
    title: 'Paper published in Cell Press Patterns',
    detail: 'First-author paper: "Strategies to include prior knowledge in omics analysis with deep neural networks."',
    link: '/publications',
  },
  {
    date: 'Feb 2025',
    title: 'Conference Presentation',
    detail: 'Presented at the UMass Boston Graduate Research Symposium.',
    link: undefined,
  },
  {
    date: 'Dec 2023',
    title: 'Passed PhD Qualifying Exam',
    detail: 'Advanced to PhD Candidacy.',
    link: undefined,
  },
]
---

<BaseLayout title="Kisan Thapa" description="PhD candidate in Computational Biology and Deep Learning at UMass Boston.">

  <!-- ── Intro ───────────────────────────────────────────────────────── -->
  <section class="flex flex-col-reverse sm:flex-row items-start gap-8 pb-12 border-b border-slate-100 dark:border-zinc-800">
    <div class="flex-1">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-zinc-50">Kisan Thapa</h1>
      <p class="mt-1 text-slate-500 dark:text-zinc-400">PhD Candidate in Computer Science</p>

      <div class="mt-5 space-y-3 text-sm text-slate-700 dark:text-zinc-300 leading-relaxed">
        <p>
          I am a PhD candidate at the
          <strong class="text-slate-900 dark:text-zinc-100">University of Massachusetts Boston</strong>,
          specializing in
          <strong class="text-slate-900 dark:text-zinc-100">Computational Biology</strong> and
          <strong class="text-slate-900 dark:text-zinc-100">Deep Learning</strong>.
        </p>
        <p>
          My research focuses on developing advanced computational methods, particularly leveraging
          deep learning, to decipher complex biological systems from omics data.
        </p>
        <p>
          I work within the{' '}
          <a
            href="https://sites.google.com/view/umb-network-biology"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-900 dark:text-zinc-100 underline underline-offset-2 hover:text-slate-500 dark:hover:text-zinc-400 transition-colors"
          >
            Network Biology Laboratory
          </a>{' '}
          under the supervision of{' '}
          <a
            href="https://sites.google.com/view/ozgunbabur"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-900 dark:text-zinc-100 underline underline-offset-2 hover:text-slate-500 dark:hover:text-zinc-400 transition-colors"
          >
            Prof. Özgün Babur
          </a>.
        </p>
      </div>

      <!-- Primary actions: CV + Resume -->
      <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
        <a
          href="https://www.cs.umb.edu/~kisan/resume/Kisan_Thapa_CV.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-slate-900 dark:text-zinc-100 underline underline-offset-2 hover:text-slate-500 dark:hover:text-zinc-400 transition-colors"
        >
          CV ↓
        </a>
        <a
          href="https://www.cs.umb.edu/~kisan/resume/Kisan_Thapa_Resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-slate-900 dark:text-zinc-100 underline underline-offset-2 hover:text-slate-500 dark:hover:text-zinc-400 transition-colors"
        >
          Resume ↓
        </a>

        <span class="text-slate-200 dark:text-zinc-700 select-none">|</span>

        <!-- Secondary links -->
        <a
          href="https://www.linkedin.com/in/kisanthapa/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 dark:text-zinc-400 underline underline-offset-2 hover:text-slate-900 dark:hover:text-zinc-100 transition-colors"
        >
          LinkedIn
        </a>
        <a
          href="https://github.com/KisanThapa"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 dark:text-zinc-400 underline underline-offset-2 hover:text-slate-900 dark:hover:text-zinc-100 transition-colors"
        >
          GitHub
        </a>
        <a
          href="https://scholar.google.com/citations?user=4Qs3ndUAAAAJ&hl=en"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 dark:text-zinc-400 underline underline-offset-2 hover:text-slate-900 dark:hover:text-zinc-100 transition-colors"
        >
          Google Scholar
        </a>
        <a
          href="/publications"
          class="text-slate-500 dark:text-zinc-400 underline underline-offset-2 hover:text-slate-900 dark:hover:text-zinc-100 transition-colors"
        >
          Publications
        </a>
      </div>
    </div>

    <!-- Profile photo -->
    <div class="flex-shrink-0">
      <img
        src="/images/profile.jpeg"
        alt="Kisan Thapa"
        class="w-28 h-28 sm:w-36 sm:h-36 rounded-full object-cover border border-slate-200 dark:border-zinc-700"
        onerror="this.style.display='none'"
      />
    </div>
  </section>

  <!-- ── News ──────────────────────────────────────────────────────── -->
  <section class="mt-12">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-zinc-500">News</h2>
    <ul class="mt-5 space-y-5">
      {news.map((item) => (
        <li class="flex gap-6 text-sm">
          <span class="w-20 flex-shrink-0 font-mono tabular-nums pt-0.5 text-slate-400 dark:text-zinc-500">
            {item.date}
          </span>
          <div>
            <p class="font-medium text-slate-900 dark:text-zinc-100">{item.title}</p>
            {item.detail && (
              <p class="mt-0.5 text-slate-500 dark:text-zinc-400">
                {item.link ? (
                  <a
                    href={item.link}
                    class="underline underline-offset-2 hover:text-slate-900 dark:hover:text-zinc-100 transition-colors"
                  >
                    {item.detail}
                  </a>
                ) : (
                  item.detail
                )}
              </p>
            )}
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- ── Recent Posts ───────────────────────────────────────────────── -->
  {posts.length > 0 && (
    <section class="mt-12 pt-12 border-t border-slate-100 dark:border-zinc-800">
      <div class="flex items-baseline justify-between">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-zinc-500">
          Recent Posts
        </h2>
        <a
          href="/blog"
          class="text-sm text-slate-500 dark:text-zinc-500 hover:text-slate-900 dark:hover:text-zinc-100 transition-colors"
        >
          All posts →
        </a>
      </div>
      <ul class="mt-5 space-y-6">
        {posts.map((post) => (
          <li class="group">
            <a href={`/blog/${post.id}/`} class="block">
              <span class="font-medium text-slate-900 dark:text-zinc-100 group-hover:underline underline-offset-2">
                {post.data.title}
              </span>
              <p class="mt-0.5 text-sm text-slate-500 dark:text-zinc-400">
                {post.data.description}
              </p>
              <p class="mt-1 text-xs text-slate-400 dark:text-zinc-500">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
                {post.data.tags.length > 0 && (
                  <span class="ml-3">{post.data.tags.join(' · ')}</span>
                )}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
  
  
  <!-- ── Education ─────────────────────────────────────────────────── -->
  <hr class="mt-12 border-slate-100 dark:border-zinc-800" />
  <section class="mt-12">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-zinc-500">Education</h2>
    <ul class="mt-5 space-y-5">
      {education.map((e) => (
        <li class="flex gap-6 text-sm">
          <span class="w-28 flex-shrink-0 tabular-nums pt-0.5 text-slate-400 dark:text-zinc-500">
            {e.period}
          </span>
          <div>
            <p class="font-medium text-slate-900 dark:text-zinc-100">{e.degree}</p>
            <p class="mt-0.5 text-slate-500 dark:text-zinc-400">{e.school}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- ── Research Interests + Skills ──────────────────────────────── -->
  <section class="mt-12 grid sm:grid-cols-2 gap-10">

    <div>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-zinc-500">
        Research Interests
      </h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {interests.map((interest) => (
          <span class="rounded border border-slate-200 dark:border-zinc-700 px-2.5 py-1 text-xs text-slate-600 dark:text-zinc-400">
            {interest}
          </span>
        ))}
      </div>
    </div>

    <div>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-zinc-500">Skills</h2>
      <div class="mt-4 space-y-3">
        {Object.entries(skills).map(([category, items]) => (
          <div>
            <p class="text-xs font-semibold uppercase text-slate-400 dark:text-zinc-600 mb-1.5">
              {category}
            </p>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => (
                <span class="rounded border border-slate-200 dark:border-zinc-700 px-2.5 py-1 text-xs text-slate-600 dark:text-zinc-400">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

  </section>


</BaseLayout>
