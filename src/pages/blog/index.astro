---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
---

<BaseLayout title="Blog — Kisan Thapa" description="Thoughts, updates, and explorations in computational biology, deep learning, and the PhD journey.">

  <div class="pb-10 border-b border-slate-100 dark:border-zinc-800">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-zinc-50">Blog</h1>
    <p class="mt-2 text-sm text-slate-500 dark:text-zinc-400">
      Thoughts, updates, and explorations in computational biology, deep learning, and the PhD journey.
    </p>
  </div>

  <ul class="mt-10 space-y-10">
    {posts.map((post) => (
      <li class="group">
        <a href={`/blog/${post.id}/`} class="block">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-zinc-100 group-hover:underline underline-offset-2 leading-snug">
            {post.data.title}
          </h2>
          <p class="mt-1.5 text-sm text-slate-600 dark:text-zinc-400 leading-relaxed">
            {post.data.description}
          </p>
          <p class="mt-2 text-xs text-slate-400 dark:text-zinc-500">
            {post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </p>
        </a>
        {post.data.tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="rounded border border-slate-200 dark:border-zinc-700 px-2.5 py-0.5 text-xs text-slate-500 dark:text-zinc-500">
                {tag}
              </span>
            ))}
          </div>
        )}
      </li>
    ))}
  </ul>

</BaseLayout>
